# =============================================================
# DogWork — Variables d'environnement
# =============================================================
# Ce fichier sert de référence. Copiez-le en `.env` et remplissez
# les valeurs réelles. Ne commitez JAMAIS le fichier `.env`.
# =============================================================

# --- Frontend (exposées au navigateur via Vite) ---
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Optionnel : "development" pour activer les outils de dev (bouton dev-login, etc.)
# Ne JAMAIS mettre "development" en production.
VITE_ENVIRONMENT="production"

# --- Backend (secrets Edge Functions — configurés dans Lovable Cloud) ---
# STRIPE_SECRET_KEY        → Clé API Stripe (restreinte)
# STRIPE_WEBHOOK_SECRET    → Secret du webhook Stripe
# RESEND_API_KEY           → Clé API Resend pour emails transactionnels
# ENVIRONMENT              → "production" ou "development"
# LOVABLE_API_KEY          → Auto-géré par Lovable Cloud
